{% extends 'free-nav/_layouts/base' %}
{% import '_includes/forms' as forms %}

{% set title = 'Settings'|t('free-nav') %}
{% set selectedSubnavItem = 'settings' %}

{% block content %}
    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('free-nav/menus/save-settings') }}
        {{ redirectInput('free-nav/settings') }}

        <h2>{{ 'Cache'|t('free-nav') }}</h2>

        {{ forms.lightswitchField({
            label: 'Enable Caching'|t('free-nav'),
            instructions: 'Cache rendered menu HTML for better performance.'|t('free-nav'),
            id: 'cacheEnabled',
            name: 'cacheEnabled',
            on: settings.cacheEnabled,
        }) }}

        {{ forms.textField({
            label: 'Cache Duration'|t('free-nav'),
            instructions: 'How long to cache menu HTML (in seconds).'|t('free-nav'),
            id: 'cacheDuration',
            name: 'cacheDuration',
            value: settings.cacheDuration,
            type: 'number',
            min: 0,
            size: 8,
        }) }}

        <hr>
        <h2>{{ 'Rendering'|t('free-nav') }}</h2>

        {{ forms.lightswitchField({
            label: 'Enable ARIA Attributes'|t('free-nav'),
            instructions: 'Automatically add ARIA attributes to rendered menus for accessibility.'|t('free-nav'),
            id: 'ariaEnabled',
            name: 'ariaEnabled',
            on: settings.ariaEnabled,
        }) }}

        {{ forms.selectField({
            label: 'Default Preset'|t('free-nav'),
            instructions: 'The default rendering preset when none is specified.'|t('free-nav'),
            id: 'defaultPreset',
            name: 'defaultPreset',
            options: [
                { label: 'Default', value: 'default' },
                { label: 'Dropdown', value: 'dropdown' },
                { label: 'Sidebar', value: 'sidebar' },
                { label: 'Breadcrumb', value: 'breadcrumb' },
                { label: 'Footer', value: 'footer' },
                { label: 'Mega Menu', value: 'mega' },
            ],
            value: settings.defaultPreset,
        }) }}

        {{ forms.textField({
            label: 'Active Class'|t('free-nav'),
            instructions: 'CSS class applied to active menu items.'|t('free-nav'),
            id: 'activeClass',
            name: 'activeClass',
            value: settings.activeClass,
            class: 'code',
        }) }}

        {{ forms.textField({
            label: 'Has Children Class'|t('free-nav'),
            instructions: 'CSS class applied to items with children.'|t('free-nav'),
            id: 'hasChildrenClass',
            name: 'hasChildrenClass',
            value: settings.hasChildrenClass,
            class: 'code',
        }) }}

        <hr>
        <h2>{{ 'API'|t('free-nav') }}</h2>

        {{ forms.lightswitchField({
            label: 'Enable REST API'|t('free-nav'),
            instructions: 'Enable the built-in REST API endpoints.'|t('free-nav'),
            id: 'restApiEnabled',
            name: 'restApiEnabled',
            on: settings.restApiEnabled,
        }) }}

        <div class="buttons">
            <button type="submit" class="btn submit">{{ 'Save'|t('app') }}</button>
        </div>
    </form>

    <hr>
    <h2>{{ 'Migration'|t('free-nav') }}</h2>

    <div class="field">
        <div class="heading">
            <label>{{ 'Migrate from Verbb Navigation'|t('free-nav') }}</label>
        </div>
        <div class="instructions">
            <p>{{ 'Import all navigations and nodes from the Verbb Navigation plugin. Existing menus with matching handles will be skipped. The Navigation plugin must still be installed.'|t('free-nav') }}</p>
        </div>
        <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('free-nav/import-export/migrate-from-navigation') }}
            <button type="submit" class="btn">{{ 'Migrate from Navigation'|t('free-nav') }}</button>
        </form>
    </div>

    <div class="field" style="margin-top: 24px;">
        <div class="heading">
            <label>{{ 'Import from JSON'|t('free-nav') }}</label>
        </div>
        <div class="instructions">
            <p>{{ 'Import a menu from a FreeNav JSON export file.'|t('free-nav') }}</p>
        </div>
        <form method="post" accept-charset="UTF-8" enctype="multipart/form-data">
            {{ csrfInput() }}
            {{ actionInput('free-nav/import-export/import') }}
            <div style="display: flex; gap: 8px; align-items: center;">
                <input type="file" name="importFile" accept=".json">
                <button type="submit" class="btn">{{ 'Import'|t('free-nav') }}</button>
            </div>
        </form>
    </div>
{% endblock %}
